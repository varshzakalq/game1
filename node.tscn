[sub_resource type="GDScript" id="GDScript_wt6go"]
resource_name = "stair_spawner"
script/source = "extends StaticBody3D


@onready var stairs = $CSGCombiner3D

var target_pos = []

func _ready() -> void:
	
	for stair in stairs.get_children():
		target_pos.append(stair.global_position.y)
		stair.global_position.y = -5


func _on_area_3d_body_entered(body: Node3D) -> void:
	if body is Time_Character:
		var tween = create_tween()
		for stair in stairs.get_children():
			tween.parallel().tween_property(stair, \"global_position:y\", target_pos.pop_front(), 2)
"

