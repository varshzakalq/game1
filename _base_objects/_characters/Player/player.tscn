[sub_resource type="GDScript" id="GDScript_x2vq2"]
resource_name = "player_camera"
script/source = "extends Camera3D

# We keep these as exports, but they will be overwritten by GlobalSettings in _ready
@export var mouse_sensitivity : float = 0.002
@export var min_pitch : float = -80.0 
@export var max_pitch : float = 70.0  

@onready var player : CharacterBody3D = get_parent()

const SENS_MULTIPLIER : float = 0.0004

func _ready() -> void:
	Input.mouse_mode = Input.MOUSE_MODE_CAPTURED
	
	# 1. Sync with current global settings immediately on spawn
	mouse_sensitivity = GlobalSettings.settings[\"sensitivity\"] * SENS_MULTIPLIER
	fov = GlobalSettings.settings[\"fov\"]
	
	# 2. Connect to EventBus signals for real-time updates
	EventBus.fov_changed.connect(_on_fov_updated)
	EventBus.sensitivity_changed.connect(_on_sens_updated)

# --- SIGNAL HANDLERS ---

func _on_fov_updated(new_fov: float) -> void:
	fov = new_fov


func _on_sens_updated(new_sens: float) -> void:
	# Convert the 0-10 scale to the 0.000 - 0.004 scale
	mouse_sensitivity = new_sens * SENS_MULTIPLIER

# --- INPUT HANDLING ---

func _unhandled_input(event: InputEvent) -> void:
	
	if rotation.z != 0:
		rotation.z = 0
	#
	#if event.is_action_pressed(\"ui_cancel\"):
		#if Input.mouse_mode == Input.MOUSE_MODE_CAPTURED:
			#Input.mouse_mode = Input.MOUSE_MODE_VISIBLE
		#else:
			#Input.mouse_mode = Input.MOUSE_MODE_CAPTURED
	
	if event is InputEventMouseMotion and Input.mouse_mode == Input.MOUSE_MODE_CAPTURED:
		# The math remains the same, but mouse_sensitivity is now correctly scaled
		player.rotate_y(-event.relative.x * mouse_sensitivity)
		rotate_x(-event.relative.y * mouse_sensitivity)
			
	if player._is_rewinding:
		return		
			
	if event is InputEventMouseMotion and Input.mouse_mode == Input.MOUSE_MODE_CAPTURED:
		
		# We multiply by mouse_sensitivity. 
		# Since your slider is 0.001 to 0.01, this scales linearly.
		player.rotate_y(-event.relative.x * mouse_sensitivity)
		rotate_x(-event.relative.y * mouse_sensitivity)
		
		rotation.x = clamp(rotation.x, deg_to_rad(min_pitch), deg_to_rad(max_pitch))
		player.camera_rotation = rotation.x
"

[sub_resource type="GDScript" id="GDScript_f4rpb"]
script/source = "class_name HUDManager
extends CanvasLayer

@export_category(\"HUD Visuals\")
# Assign your heart/portrait image in the inspector here!
@export var player_portrait: Texture2D 
# Adds a nice slider in the Inspector from 0.0 (invisible) to 1.0 (solid light)
@export_range(0.0, 1.0) var hologram_opacity: float = 0.8

# --- INTERNAL TRACKING ---
var _aging_component: Component = null

# Portrait Tracking
var _portrait_rect: TextureRect
var _portrait_mat: ShaderMaterial
var _current_portrait_time: float = 0.0

func _ready() -> void:
	_setup_portrait()
	
	# Wait one frame for the player to fully spawn before searching
	call_deferred(\"_scan_for_aging_component\")

func _setup_portrait() -> void:
	if player_portrait == null:
		push_warning(\"HUD: No player_portrait assigned in the inspector!\")
		return
		
	_portrait_rect = TextureRect.new()
	_portrait_rect.texture = player_portrait
	
	_portrait_rect.expand_mode = TextureRect.EXPAND_IGNORE_SIZE
	_portrait_rect.stretch_mode = TextureRect.STRETCH_KEEP_ASPECT_CENTERED
	_portrait_rect.custom_minimum_size = Vector2(128.0, 128.0)
	_portrait_rect.size = Vector2(128.0, 128.0) 
	
	var margin = MarginContainer.new()
	margin.set_anchors_preset(Control.PRESET_TOP_LEFT)
	margin.add_theme_constant_override(\"margin_left\", 30)
	margin.add_theme_constant_override(\"margin_top\", 30)
	margin.mouse_filter = Control.MOUSE_FILTER_IGNORE 
	
	add_child(margin)
	margin.add_child(_portrait_rect)
	
	_portrait_rect.pivot_offset = _portrait_rect.size / 2.0
	
	_portrait_mat = ShaderMaterial.new()
	var shader = Shader.new()
	
	shader.code = \"\"\"
	shader_type canvas_item;
	render_mode blend_add; 
	
	uniform float aging_severity : hint_range(0.0, 1.0) = 0.0;
	
	// NEW: The global opacity control
	uniform float base_opacity : hint_range(0.0, 1.0) = 0.8;
	
	// Bumped the default alpha of the colors back to 1.0
	uniform vec4 healthy_color : source_color = vec4(0.0, 0.8, 1.0, 1.0); 
	uniform vec4 sick_color : source_color = vec4(1.0, 0.1, 0.1, 1.0);    
	
	void fragment() {
		vec4 tex_color = texture(TEXTURE, UV);
		float gray = dot(tex_color.rgb, vec3(0.299, 0.587, 0.114));
		
		vec4 current_color = mix(healthy_color, sick_color, aging_severity);
		
		float scanline = sin(SCREEN_UV.y * 800.0 - TIME * 10.0) * 0.1;
		float grid = sin(UV.x * 150.0) * sin(UV.y * 150.0) * 0.05;
		
		float glitch = 1.0;
		if (aging_severity > 0.7) {
			float noise = fract(sin(dot(UV + TIME, vec2(12.9898, 78.233))) * 43758.5453);
			if (noise > (1.5 - aging_severity)) {
				glitch = 0.2; 
			}
		}
		
		vec3 final_rgb = (vec3(gray) * current_color.rgb) + scanline + grid;
		
		// Multiplied the final alpha by your new base_opacity variable
		COLOR = vec4(final_rgb, tex_color.a * current_color.a * glitch * base_opacity);
	}
	\"\"\"
	_portrait_mat.shader = shader
	_portrait_rect.material = _portrait_mat
	
	# Pass your chosen Inspector value into the shader immediately!
	_portrait_mat.set_shader_parameter(\"base_opacity\", hologram_opacity)

func _scan_for_aging_component() -> void:
	if Globals.player == null:
		return
		
	# Look directly for the one specific component we care about
	for child in Globals.player.get_children():
		if child is Component and child.Component_Type == Component.Component_type.Aging:
			_aging_component = child
			break

func _process(delta: float) -> void:
	# If we haven't found the component or the UI hasn't built, do nothing
	if _aging_component == null or _portrait_rect == null: 
		return
	
	var current_age = _aging_component.get(\"current_age\")
	
	if current_age != null:
		_animate_portrait(current_age, delta)



func _animate_portrait(age: float, delta: float) -> void:
	var normalized_age = clamp(age / 100.0, 0.0, 1.0)
	
	# 1. DESATURATION
	var saturation = 1.0 - pow(normalized_age, 2.0)
	#_portrait_mat.set_shader_parameter(\"saturation\", saturation)
	# Send the normalized age directly into the shader to drive the color shift and glitching
	_portrait_mat.set_shader_parameter(\"aging_severity\", normalized_age)
	
	# 2. COLOR SHIFT
	var healthy_color = Color.WHITE
	var sick_color = Color(0.7, 0.75, 0.85, 1.0)
	_portrait_rect.modulate = healthy_color.lerp(sick_color, normalized_age)
	
	# 3. HEARTBEAT ANIMATION
	# Speed: Starts at a healthy 6.0, drops to a sluggish 1.5 at max age
	var pulse_speed = lerp(6.0, 1.5, normalized_age) 
	
	# Strength: Kept relatively consistent so the visual read is always clear
	var pulse_strength = lerp(0.08, 0.04, normalized_age) 
	
	_current_portrait_time += delta * pulse_speed
	
	# Wrapping the sine wave in max() ensures the heart only expands outward 
	# and has a slight visual \"rest\" at its base size between beats
	var pulse = max(0.0, sin(_current_portrait_time)) * pulse_strength
	
	# 4. LOCK THE PIVOT AND APPLY SCALE
	# Forcing the pivot to the center right here guarantees it never wobbles off-axis
	_portrait_rect.pivot_offset = _portrait_rect.size / 2.0
	
	var target_scale = Vector2.ONE + Vector2(pulse, pulse)
	_portrait_rect.scale = _portrait_rect.scale.lerp(target_scale, 15.0 * delta)
	
	# Explicitly kill any residual rotation just to be safe
	_portrait_rect.rotation = 0.0
"

